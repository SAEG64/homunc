data$x3 <- as.numeric(data$x3)
x3_mean <- mean(data$x3, na.rm = TRUE)  # Ensure x3 is numeric and has no NAs
# Get the posterior coefficients for the fixed effects
b_x1 <- posterior$b_x12
b_x2 <- posterior$b_x22
b_interaction <- posterior$`b_x12:x22`
# Initialize a matrix to store predictions for all posterior samples and grid points
predictions_matrix <- matrix(NA, nrow = length(b_x1) * nrow(grid), ncol = 1)
# Loop over posterior samples and generate predictions for each grid point
for (i in 1:length(b_x1)) {
for (j in 1:nrow(grid)) {
# Calculate the linear predictor for this grid point and posterior sample
linear_predictor <- b_x1[i] * as.numeric(grid$x1[j]) +
b_x2[i] * as.numeric(grid$x2[j]) +
b_interaction[i] * as.numeric(grid$x1[j]) * as.numeric(grid$x2[j]) +
x3_mean
# Apply inverse logit for logistic regression
predictions_matrix[(i - 1) * nrow(grid) + j] <- exp(linear_predictor) / (1 + exp(linear_predictor))
}
}
# Convert the matrix of predictions to a data frame
predictions_df <- data.frame(grid, predictions = predictions_matrix)
# Plot using ggplot2
ggplot(predictions_df, aes(x = x1, y = predictions, color = x2)) +
geom_line() +
labs(x = "x1", y = "Predicted Probability", color = "x2") +
theme_minimal() +
