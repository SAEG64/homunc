## Requirements
library('readr')
library(ROCR)
library(dplyr)
library(ggplot2)
# Set working directory
set.seed(123)
filepath <- paste(dirname(rstudioapi::getSourceEditorContext()$path), "/", sep = "")
setwd(filepath)
# Function to extract midpoints from the interval string
get_midpoint <- function(interval) {
# Extract the lower and upper bounds using regular expressions
bounds <- as.numeric(unlist(regmatches(interval, gregexpr("[0-9.]+", interval))))
# Calculate the midpoint
midpoint <- mean(bounds)
return(midpoint)
}
# Data import
load("homunc_Bayes_fit_res_threeVar.RData")
# Add optimal policy
data$x4 <- dat$x21_optimal_policy_binary
data$x4[data$x4 == 2] <- 0.5
data$x5 = post_preds[,1]
## Plot weather type effect on pMod
# Data preprocessing
dat$x7_weather_type[dat$x7_weather_type == 1] <- "bad weather"
dat$x7_weather_type[dat$x7_weather_type == 2] <- "good weather"
data$x2 <- dat$x7_weather_type
# Prep data fro visualization
plot_data <- data.frame(
GroundTruth = as.numeric(true_class),
Predicted = as.numeric(preds),
x1 = data$x1,
x2 = data$x2,
x3 = data$x3,
policy = data$x4,
policy2 = data$x5,
group = data$group
)
if (is.factor(plot_data$x3) == FALSE) {
plot_data$bin <- plot_data$x3  # Adjust number of bins as needed
}else {
plot_data$bin <- plot_data$x3  # Adjust number of bins as needed
}
# Aggregate the count of occurrences per bin and calculate average predicted probabilities for each bin
bin_data_sbj <- plot_data %>%
group_by(bin, x1, x2, group) %>%
summarize(
count = n(),  # Count the occurrences in each bin
avg_pred_prob = mean(policy),
avg_pred_prob2 = mean(policy2),
avg_prob = mean(GroundTruth),
#.groups = 'drop'
)
bin_data <- bin_data_sbj %>%
group_by(bin, x2) %>%
summarize(
count = mean(count),  # Average counts in each bin
avg_pred_prob = mean(avg_pred_prob),
avg_pred_prob2 = mean(avg_pred_prob2),
avg_prob = mean(avg_prob),
.groups = 'drop'
)
# Convert bin intervals to midpoints
midpoints <- sapply(bin_data$bin, get_midpoint)
bin_data$bin <- midpoints
# Create the plot
p1 <- ggplot(bin_data, aes(x = bin)) +
# Plot the predicted logistic curve (policy)
geom_line(aes(y = avg_pred_prob, group = x2, color = paste("Optimal policy -", x2)), size = 1, linetype = "dashed") +
# geom_point(aes(y = avg_pred_prob, color = paste("Optimal policy -", x2)), size = 1.5, shape = 5) +
# Plot the predicted logistic curve (policy2)
geom_line(aes(y = avg_pred_prob2, group = x2, color = paste("Factorial model -", x2)), size = 1, linetype = "solid") +
geom_point(aes(y = avg_pred_prob2, color = paste("Factorial model -", x2)), size = 1.5, shape = 16) +
# Plot the actual observed responses as bubbles, scaled by the count in each bin, colored by weather type
geom_point(aes(y = avg_prob, size = as.numeric(count), color = paste("Factorial model -", x2)), alpha = 0.7, show.legend = TRUE) +
# Customize the plot
ylim(0, 1) +  # Set y-axis limits from 0 to 1
labs(x = ~italic("p")~" success", y = "Foraging likelihood", title = "Weather type effect") + # Removed color = "Weather type"
scale_size_continuous(name = "Sampling size", range = c(1.5, 4), guide = "legend") +  # Show size legend with proper name
scale_color_manual(name = NULL, values = c("Optimal policy - bad weather" = "#FF0000",
"Optimal policy - good weather" = "#0066CC",
"Factorial model - bad weather" = "#FF6666",
"Factorial model - good weather" = "#66B2FF")) +
theme_minimal() +
theme(legend.position = "right")  # Show legend at right
# Create the plot
p1 <- ggplot(bin_data, aes(x = bin)) +
# Plot the predicted logistic curve (policy)
geom_line(aes(y = avg_pred_prob, group = x2, color = paste("Optimal policy -", x2)), size = 1, linetype = "dashed") +
# geom_point(aes(y = avg_pred_prob, color = paste("Optimal policy -", x2)), size = 1.5, shape = 5) +
# Plot the predicted logistic curve (policy2)
geom_line(aes(y = avg_pred_prob2, group = x2, color = paste("Factorial model -", x2)), size = 1, linetype = "solid") +
geom_point(aes(y = avg_pred_prob2, color = paste("Factorial model -", x2)), size = 1.5, shape = 16) +
# Plot the actual observed responses as bubbles, scaled by the count in each bin, colored by weather type
geom_point(aes(y = avg_prob, size = as.numeric(count), color = paste("Factorial model -", x2)), alpha = 0.7, show.legend = TRUE) +
# Customize the plot
ylim(0, 1) +  # Set y-axis limits from 0 to 1
labs(x = ~italic("p")~" success", y = "Foraging likelihood", title = "Weather type effect") + # Removed color = "Weather type"
scale_size_continuous(name = "Sampling size", range = c(1.5, 4), guide = "legend") +  # Show size legend with proper name
scale_color_manual(
name = NULL,
values = c(
"Optimal policy - bad weather" = "#800080",    # Purple
"Optimal policy - good weather" = "#DA70D6",   # Orchid (lighter purple)
"Factorial model - bad weather" = "#FF8C00",   # Dark orange
"Factorial model - good weather" = "#FFA500"   # Orange
)
) +
theme_minimal() +
theme(legend.position = "right")  # Show legend at right
# Apply publication-ready theme
p1_pub <- p1 + theme(
axis.title.x = element_text(size = 12),   # Balanced x-axis title text size
axis.title.y = element_text(size = 12),   # Balanced y-axis title text size
axis.text.x = element_text(size = 10),    # Readable x-axis tick label text size
axis.text.y = element_text(size = 10),    # Readable y-axis tick label text size
plot.title = element_text(size = 14, margin = margin(b = 20)),     # Moderate plot title text size with reasonable margin
legend.title = element_text(size = 10),   # Legend title text size
legend.text = element_text(size = 9),     # Legend text size
strip.text = element_text(size = 10),     # Facet strip text size
panel.grid.major = element_line(size = 0.3),  # Subtle major grid line thickness
panel.grid.minor = element_line(size = 0.2),   # Subtle minor grid line thickness
aspect.ratio = 0.8,                       # Optimal aspect ratio for publication
legend.position = "right",                # Show legend at right
legend.key.size = unit(0.8, "cm"),       # Smaller legend key size
plot.margin = margin(t = 10, r = 10, b = 10, l = 10)  # Add margins around plot
)
p1_pub
